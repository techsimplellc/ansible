# PPF Webserver — Hardened SSH config
# Managed by Ansible — do not edit manually
# Role: webserver_hardening / 03_ssh.yml

Port {{ ssh_port }}
Protocol 2
AddressFamily inet

# No root login — by password or key
PermitRootLogin no

# Key auth only — no passwords
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
PasswordAuthentication no
PermitEmptyPasswords no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
UsePAM yes

# Attack surface reduction
X11Forwarding no
AllowTcpForwarding no
GatewayPorts no
PermitUserEnvironment no
AllowAgentForwarding no
PermitTunnel no

# Session limits
LoginGraceTime 30
MaxAuthTries 3
MaxSessions 4
ClientAliveInterval 300
ClientAliveCountMax 2

# Verbose auth logging
SyslogFacility AUTH
LogLevel VERBOSE

# Ciphers — Mozilla Modern SSH profile
KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Explicit user allowlist
AllowUsers {{ ssh_allow_users | join(' ') }}

# SFTP subsystem — required for Ansible file transfer
Subsystem sftp /usr/lib/openssh/sftp-server

Banner /etc/ssh/banner.txt
