---
# omnimail_vault.yml — secrets for the OmniMail stack (srv6)
#
# Setup:
#   cp omnimail_vault.yml.example omnimail_vault.yml
#   ansible-vault encrypt playbooks/vars/omnimail_vault.yml
#
# Generate values:
#   omnimail_db_password      : openssl rand -hex 24
#   omnimail_session_secret   : openssl rand -hex 32
#   omnimail_encryption_key   : openssl rand -hex 32
#
# OAuth credentials (leave blank to disable that provider):
#   Google  : https://console.cloud.google.com/apis/credentials
#   Microsoft: https://portal.azure.com → App registrations
#   Yahoo   : https://developer.yahoo.com/apps/

omnimail_db_password: "CHANGE_ME"
omnimail_session_secret: "CHANGE_ME"
omnimail_encryption_key: "CHANGE_ME"

# Google OAuth (leave blank to disable)
omnimail_google_client_id: ""
omnimail_google_client_secret: ""

# Microsoft OAuth (leave blank to disable)
omnimail_microsoft_client_id: ""
omnimail_microsoft_client_secret: ""

# Yahoo OAuth (leave blank to disable)
omnimail_yahoo_client_id: ""
omnimail_yahoo_client_secret: ""
