---
# anythingllm_vault.yml — secrets for the AnythingLLM stack (srv5)
#
# Setup:
#   cp anythingllm_vault.yml.example anythingllm_vault.yml
#   ansible-vault encrypt playbooks/vars/anythingllm_vault.yml
#
# Generate values:
#   anythingllm_jwt_secret : openssl rand -base64 32

anythingllm_jwt_secret: "CHANGE_ME"
