---
# paperless_vault.yml — secrets for the Paperless-ngx stack (srv6)
#
# Setup:
#   cp paperless_vault.yml.example paperless_vault.yml
#   ansible-vault encrypt playbooks/vars/paperless_vault.yml
#
# Generate values:
#   paperless_db_password    : openssl rand -hex 24
#   paperless_secret_key     : openssl rand -hex 32
#   paperless_admin_password : choose a strong password
#   paperless_api_token      : generated in Paperless-ngx UI after first login
#                              Profile → API Token (two-pass — leave blank initially)

paperless_db_password: "CHANGE_ME"
paperless_secret_key: "CHANGE_ME"
paperless_admin_password: "CHANGE_ME"
paperless_api_token: "CHANGE_ME"
