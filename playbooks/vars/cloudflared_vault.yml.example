---
# cloudflared_vault.yml — secrets for the cloudflared stack (srv1)
#
# Setup:
#   cp cloudflared_vault.yml.example cloudflared_vault.yml
#   ansible-vault encrypt playbooks/vars/cloudflared_vault.yml
#
# Generate token:
#   Cloudflare Zero Trust dashboard → Networks → Tunnels → <your tunnel> → Configure → Token

cloudflared_tunnel_token: "CHANGE_ME"
