---
# simple_office_vault.yml — secrets for the Simple Office stack (srv6)
#
# Setup:
#   cp simple_office_vault.yml.example simple_office_vault.yml
#   ansible-vault encrypt playbooks/vars/simple_office_vault.yml
#
# Generate values:
#   so_db_password           : openssl rand -hex 24
#   so_jwt_secret            : openssl rand -hex 32
#   so_onlyoffice_jwt_secret : openssl rand -hex 32
#   so_session_secret        : openssl rand -hex 32
#
# Two-pass values (added after Authentik OIDC client is configured — see simple-office.yml):
#   so_oidc_client_id        : from Authentik admin UI after provider creation
#   so_oidc_client_secret    : from Authentik admin UI after provider creation
#
# OnlyOffice document server (bundled with Simple Office):
#   onlyoffice_db_password   : openssl rand -hex 24
#   onlyoffice_jwt_secret    : openssl rand -hex 32

so_db_password: "CHANGE_ME"
so_jwt_secret: "CHANGE_ME"
so_onlyoffice_jwt_secret: "CHANGE_ME"
so_session_secret: "CHANGE_ME"
so_oidc_client_id: "CHANGE_ME"
so_oidc_client_secret: "CHANGE_ME"
onlyoffice_db_password: "CHANGE_ME"
onlyoffice_jwt_secret: "CHANGE_ME"
