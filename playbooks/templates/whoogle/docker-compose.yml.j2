# Repo path: ~/git/ansible/playbooks/templates/whoogle/docker-compose.yml.j2
---
# Whoogle — Self-hosted, ad-free Google search proxy
# Docs : https://github.com/benbusby/whoogle-search
# Image: https://hub.docker.com/r/benbusby/whoogle-search
#
# Access via NPM proxy — do not expose port 5000 externally

services:
  whoogle:
    image: benbusby/whoogle-search:{{ whoogle_version }}
    container_name: whoogle
    restart: unless-stopped
    pids_limit: 50
    mem_limit: 256m
    memswap_limit: 256m
    user: whoogle
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    tmpfs:
      - /config/:size=10M,uid=927,gid=927,mode=1700
      - /var/lib/tor/:size=15M,uid=927,gid=927,mode=1700
      - /run/tor/:size=1M,uid=927,gid=927,mode=1700
    environment:
      WHOOGLE_AUTOCOMPLETE: 1
      WHOOGLE_CONFIG_LANGUAGE: lang_en
      WHOOGLE_CONFIG_SEARCH_LANGUAGE: lang_en
      WHOOGLE_CONFIG_THEME: dark
      WHOOGLE_CONFIG_URL: "https://search.techsimple.dev"
    expose:
      - "5000"
    networks:
      - proxy

networks:
  proxy:
    external: true
