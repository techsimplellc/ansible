# Repo path: ~/git/ansible/playbooks/templates/filebrowser/docker-compose.yml.j2
---
# FileBrowser Quantum — Self-hosted file manager with OnlyOffice integration
# Docs : https://github.com/gtsteffaniak/filebrowser
# Image: https://hub.docker.com/r/gtsteffaniak/filebrowser
#
# Exposed via cloudflared tunnel through NPM on srv1.
# NPM upstream: http://192.168.68.16:8085
#
# OnlyOffice integration:
#   - ONLYOFFICE_SERVER must point to the public OnlyOffice URL (via NPM/tunnel)
#     so the browser can reach it for document editing.
#   - JWT_SECRET must match onlyoffice_jwt_secret in vault.
#
# First login: admin / set via FB_ADMIN_PASSWORD
# Change password immediately after first login.

services:
  filebrowser:
    image: gtstef/filebrowser:latest
    container_name: filebrowser
    restart: unless-stopped
    environment:
      FB_ADMIN_USERNAME: admin
      FB_ADMIN_PASSWORD: "{{ filebrowser_admin_password }}"
      # OnlyOffice integration
      ONLYOFFICE_SERVER: "https://onlyoffice.{{ ansible_domain | default('example.com') }}"
      ONLYOFFICE_JWT_SECRET: "{{ onlyoffice_jwt_secret }}"
    volumes:
      - "{{ stacks_root }}/filebrowser/data:/data"
      - /opt/files:/srv                             # Shared file storage root
    ports:
      - "8085:80"       # Exposed for NPM proxy on srv1
    networks:
      - proxy

networks:
  proxy:
    external: true
