# Repo path: ~/git/ansible/playbooks/templates/homarr/docker-compose.yml.j2
---
# Homarr — Self-hosted application dashboard
# Docs : https://homarr.dev/docs/getting-started/installation/docker/
# Image: https://github.com/homarr-labs/homarr/pkgs/container/homarr
#
# Exposed on dev1 port 7575.
# All configuration is done via the web UI — no YAML files required.
# SECRET_ENCRYPTION_KEY: generate with: openssl rand -hex 32

services:
  homarr:
    image: ghcr.io/homarr-labs/homarr:{{ homarr_version }}
    container_name: homarr
    restart: unless-stopped
    environment:
      SECRET_ENCRYPTION_KEY: "{{ homarr_secret_key }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro   # Docker integration
      - "{{ stacks_root }}/homarr/appdata:/appdata"
    ports:
      - "7575:7575"
    networks:
      - proxy

networks:
  proxy:
    external: true
