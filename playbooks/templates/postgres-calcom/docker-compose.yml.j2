# Repo path: ~/git/ansible/playbooks/templates/postgres-calcom/docker-compose.yml.j2
---
# PostgreSQL — Dedicated instance for cal.com
# Docs: https://hub.docker.com/_/postgres

services:
  postgres-calcom:
    image: postgres:16-alpine
    container_name: postgres-calcom
    restart: unless-stopped
    environment:
      POSTGRES_USER: calcom
      POSTGRES_PASSWORD: "{{ calcom_db_password }}"
      POSTGRES_DB: calcom
    volumes:
      - postgres_calcom_data:/var/lib/postgresql/data
    ports:
      - "5434:5432"     # Non-standard host port — avoids conflict with other postgres instances
    networks:
      - proxy
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U calcom -d calcom"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_calcom_data:

networks:
  proxy:
    external: true
