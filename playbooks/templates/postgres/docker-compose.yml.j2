# Repo path: ~/git/ansible/playbooks/templates/postgres/docker-compose.yml.j2
---
# PostgreSQL — Relational database for Firefly III
# Docs : https://hub.docker.com/_/postgres
# Image: https://hub.docker.com/_/postgres

services:
  postgres:
    image: postgres:16-alpine
    container_name: postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: firefly
      POSTGRES_PASSWORD: "{{ firefly_db_password }}"
      POSTGRES_DB: firefly
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"     # Required for Ansible wait_for readiness check
    networks:
      - proxy
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U firefly -d firefly"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_data:

networks:
  proxy:
    external: true
