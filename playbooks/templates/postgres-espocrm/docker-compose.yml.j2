# Repo path: ~/git/ansible/playbooks/templates/postgres-espocrm/docker-compose.yml.j2
---
# PostgreSQL — Dedicated instance for EspoCRM
# Docs: https://hub.docker.com/_/postgres

services:
  postgres-espocrm:
    image: postgres:16-alpine
    container_name: postgres-espocrm
    restart: unless-stopped
    environment:
      POSTGRES_USER: espocrm
      POSTGRES_PASSWORD: "{{ espocrm_db_password }}"
      POSTGRES_DB: espocrm
    volumes:
      - postgres_espocrm_data:/var/lib/postgresql/data
    ports:
      - "5435:5432"     # Non-standard host port — avoids conflict with other postgres instances
    networks:
      - proxy
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U espocrm -d espocrm"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_espocrm_data:

networks:
  proxy:
    external: true
