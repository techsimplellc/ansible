# Repo path: ~/git/ansible/playbooks/templates/postgres-onlyoffice/docker-compose.yml.j2
---
# PostgreSQL — Dedicated instance for OnlyOffice CE
# Docs: https://hub.docker.com/_/postgres

services:
  postgres-onlyoffice:
    image: postgres:16-alpine
    container_name: postgres-onlyoffice
    restart: unless-stopped
    environment:
      POSTGRES_USER: onlyoffice
      POSTGRES_PASSWORD: "{{ onlyoffice_db_password }}"
      POSTGRES_DB: onlyoffice
    volumes:
      - postgres_onlyoffice_data:/var/lib/postgresql/data
    ports:
      - "5436:5432"
    networks:
      - proxy
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U onlyoffice -d onlyoffice"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_onlyoffice_data:

networks:
  proxy:
    external: true
