#!/usr/bin/env bash
# pre-commit: scan staged files for secrets before allowing a commit.
# Managed in-repo at hooks/pre-commit — activated via core.hooksPath=hooks.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FOUND=0

# Patterns: <label>:<regex>
PATTERNS=(
  "Google OAuth client secret:GOCSPX-[0-9A-Za-z_-]{28,}"
  "Google OAuth client ID:[0-9]+-[0-9a-z]+\.apps\.googleusercontent\.com"
  "AWS access key:AKIA[0-9A-Z]{16}"
  "AWS secret key:['\"]?[0-9a-zA-Z/+]{40}['\"]?"
  "Private key header:-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----"
  "Generic password in YAML:password:\s+['\"]?[A-Za-z0-9!@#$%^&*()_+\-=]{12,}['\"]?"
  "Generic secret in YAML:secret[_\s]*:\s+['\"]?[A-Za-z0-9!@#$%^&*()_+\-=]{12,}['\"]?"
  "Generic token in YAML:token:\s+['\"]?[A-Za-z0-9._\-]{20,}['\"]?"
  "Generic API key:api[_-]?key\s*[=:]\s*['\"]?[A-Za-z0-9._\-]{16,}['\"]?"
  "Cloudflare tunnel token:eyJ[A-Za-z0-9_-]{100,}"
)

# Files/patterns to skip (vault-encrypted files, example placeholders)
SKIP_PATTERNS=(
  "vault\.yml$"
  "vault\.yaml$"
  "\*\* Look in secrets vault \*\*"
  "REDACTED"
  "your[_-].*here"
  "changeme"
  "<.*>"
)

# Get staged files (added or modified, not deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

check_file() {
  local file="$1"

  # Skip binary files
  if ! git show ":$file" | file - | grep -q "text"; then
    return
  fi

  # Skip vault-encrypted files
  if echo "$file" | grep -qE "vault\.(yml|yaml)$"; then
    return
  fi

  local content
  content=$(git show ":$file")

  # Skip if file is ansible-vault encrypted
  if echo "$content" | head -1 | grep -q '^\$ANSIBLE_VAULT'; then
    return
  fi

  for entry in "${PATTERNS[@]}"; do
    local label="${entry%%:*}"
    local pattern="${entry#*:}"

    # Check each matching line against skip patterns
    while IFS= read -r line; do
      local skip=0
      for skip_pat in "${SKIP_PATTERNS[@]}"; do
        if echo "$line" | grep -qE "$skip_pat"; then
          skip=1
          break
        fi
      done

      if [[ $skip -eq 0 ]]; then
        if [[ $FOUND -eq 0 ]]; then
          echo -e "\n${RED}COMMIT BLOCKED — potential secrets detected:${NC}\n"
        fi
        echo -e "  ${RED}[FAIL]${NC} ${YELLOW}${label}${NC}"
        echo -e "         File: ${file}"
        echo -e "         Match: $(echo "$line" | sed 's/[^ ]*secret[^ ]*/[REDACTED]/gI' | cut -c1-120)"
        echo ""
        FOUND=1
        break
      fi
    done < <(echo "$content" | grep -iE -- "$pattern" || true)
  done
}

for file in $STAGED_FILES; do
  check_file "$file"
done

if [[ $FOUND -ne 0 ]]; then
  echo -e "${RED}Fix the issues above before committing.${NC}"
  echo -e "To bypass (dangerous): ${YELLOW}git commit --no-verify${NC}\n"
  exit 1
fi

exit 0
